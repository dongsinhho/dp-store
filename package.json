{
  "name": "dp-store",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest --run",
    "test:watch": "vitest",
    "pb:seed": "npx tsx pocketbase/seed.ts",
    "pb:setup": "node -e \"const {execSync}=require('child_process');const isWin=process.platform==='win32';if(isWin){execSync('powershell -ExecutionPolicy Bypass -File pocketbase/setup.ps1',{stdio:'inherit'})}else{execSync('bash pocketbase/setup.sh',{stdio:'inherit'})}\"",
    "pb:start": "node -e \"const {execSync}=require('child_process');const isWin=process.platform==='win32';const bin=isWin?'pocketbase\\\\pocketbase.exe':'pocketbase/pocketbase';execSync(bin+' serve --http=127.0.0.1:8090 --dir=./pocketbase/pb_data --migrationsDir=./pocketbase/pb_migrations',{stdio:'inherit'})\""
  },
  "dependencies": {
    "lucide-react": "^1.16.0",
    "next": "14.2.35",
    "pocketbase": "^0.27.0",
    "react": "^18",
    "react-dom": "^18",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "fast-check": "^4.8.0",
    "jsdom": "^29.1.1",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.22.3",
    "typescript": "^5",
    "vitest": "^4.1.7"
  }
}
